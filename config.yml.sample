cache:
  ttl_mooer: 86400
  ttl_reddit: 43200
  ttl_youtube: 172800
email:
  address: your_email@example.com
  draft_folder: Drafts
  imap:
    folder: INBOX
    port: 993
    server: imap.example.com
    ssl: true
  password: YOUR_EMAIL_PASSWORD
  smtp:
    port: 465
    server: smtp.example.com
    ssl: true
external_services:
  mooer_website:
    url: https://www.mooeraudio.com
  reddit:
    client_id: your_reddit_client_id_here
    client_secret: your_reddit_client_secret_here
    user_agent: MOOER_Email_Automation/1.0
  youtube:
    api_key: your_youtube_api_key_here
logging:
  level: INFO
  path: logs/email_automation.log
part_prices:
  GE200:
    screen: 7.6
  GE200 Pro Li:
    battery: 44
  GE250:
    screen: 7.6
  GE300:
    screen: 16
  GL100:
    screen: 9.5
paths:
  email_templates: ./售后模板/Customer Service Email.txt
  pdf_reader: ./pdf_reader.py
  product_manuals: ./MOOER产品说明书/
processing:
  interval: 5
  max_emails_per_run: 20
response:
  format: plain_text
  language: English
  max_length: 1000