# Email Automation System Environment Variables

# Email Credentials
EMAIL_ADDRESS=support@mooeraudio.com
EMAIL_PASSWORD=YJbfQNeArD5dxk3T

# IMAP Settings
IMAP_SERVER=imap.exmail.qq.com
IMAP_PORT=993
IMAP_SSL=True
IMAP_FOLDER=INBOX

# SMTP Settings
SMTP_SERVER=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SSL=True

# Draft Folder
DRAFT_FOLDER=Drafts

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/email_automation.log

# Processing Interval (minutes)
PROCESSING_INTERVAL=5
MAX_EMAILS_PER_RUN=10

# External Services Configuration
# MOOER Website
MOOER_WEBSITE_URL=https://www.mooeraudio.com

# YouTube API (optional)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit API (optional)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=MOOER_Email_Automation/1.0

# Cache Configuration (seconds)
CACHE_TTL_MOOER=86400
CACHE_TTL_YOUTUBE=172800
CACHE_TTL_REDDIT=43200
